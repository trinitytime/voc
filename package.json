{
  "name": "voc",
  "license": "MIT",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "watch": "concurrently \"bun run watch:web\" \"bun run watch:server\"",
    "watch:web": "cd apps/web && bun run watch",
    "watch:server": "cd apps/server && bun run watch",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "clean": "rm -rf packages/*/dist node_modules/.cache .turbo",
    "outdated": "find . -type f -name 'package.json' -not -path './.git/*' -not -path '*/node_modules/*' -execdir bun outdated \\;",
    "update": "find . -type f -name 'package.json' -not -path './.git/*' -not -path '*/node_modules/*' -execdir bun update \\;",
    "upgrade": "npm run outdated && npm run update",
    "link": "find . -type f -name 'package.json' -not -path './.git/*' -not -path '*/node_modules/*' -execdir bun link \\;"
  },
  "workspaces": [
    "apps/*",
    "packages/*",
    "plugins/*"
  ],
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/node": "^25.7.0",
    "@typescript/native-preview": "^7.0.0-dev.20260513.1",
    "concurrently": "^9.2.1",
    "oxfmt": "^0.48.0",
    "oxlint": "^1.64.0",
    "oxlint-tsgolint": "^0.22.1",
    "turbo": "^2.9.12",
    "typescript": "^6.0.3"
  }
}